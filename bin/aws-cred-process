#!/bin/bash
# Reads session creds from JSON file and adds a short expiration
# so the AWS SDK re-invokes this script frequently, picking up refreshed creds.

profile="${1:-default}"
creds_file="$HOME/.aws/session-creds-${profile}.json"

if [ ! -f "$creds_file" ]; then
    echo "Error: $creds_file not found. Run aws-from-clipboard first." >&2
    exit 1
fi

# Add Expiration 60 seconds from now so SDK re-reads on next call
expiration=$(date -u -v+60S '+%Y-%m-%dT%H:%M:%SZ')

python3 -c "
import json, sys
with open('$creds_file') as f:
    creds = json.load(f)
creds['Expiration'] = '$expiration'
json.dump(creds, sys.stdout)
"
