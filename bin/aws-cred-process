#!/bin/bash
# Emits session creds (written by aws-from-clipboard) with a short
# Expiration so the AWS SDK re-invokes this script frequently and picks
# up refreshed creds. Pure bash — no python startup on every aws call.

profile="${1:-default}"
creds_file="$HOME/.aws/session-creds-${profile}.json"

if [ ! -f "$creds_file" ]; then
    echo "Error: $creds_file not found. Run aws-from-clipboard first." >&2
    exit 1
fi

expiration=$(date -u -v+60S '+%Y-%m-%dT%H:%M:%SZ')

# Extract each field from the controlled-format JSON we wrote ourselves.
extract() {
    grep -o "\"$1\": *\"[^\"]*\"" "$creds_file" | sed 's/.*: *"//; s/"$//'
}
ak=$(extract AccessKeyId)
sk=$(extract SecretAccessKey)
st=$(extract SessionToken)

if [ -n "$st" ]; then
    printf '{"Version":1,"AccessKeyId":"%s","SecretAccessKey":"%s","SessionToken":"%s","Expiration":"%s"}\n' \
        "$ak" "$sk" "$st" "$expiration"
else
    printf '{"Version":1,"AccessKeyId":"%s","SecretAccessKey":"%s","Expiration":"%s"}\n' \
        "$ak" "$sk" "$expiration"
fi
